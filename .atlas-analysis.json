  "keyFeatures": [
    "Omnichannel inbox (website, email, Facebook, Instagram, Twitter, WhatsApp, Telegram, Line, SMS)",
    "Captain AI agent for automated support responses",
    "Help Center portal with articles and FAQs",
    "Team collaboration with private notes and mentions",
    "Contact management with segments and custom attributes",
    "Automation rules and workflows",
    "Live chat widget and SDK",
    "Reports and analytics (CSAT, agent performance, conversation metrics)",
    "Integrations (Slack, Dialogflow, Shopify, Linear, Google Translate)",
    "Multi-language support and internationalization"
  ],
  "publicApiSurface": [
    "POST /api/v1/accounts - Create account",
    "GET /api/v1/accounts/:id - Get account details",
    "GET /api/v1/accounts/:account_id/agents - List agents",
    "POST /api/v1/accounts/:account_id/agents - Create agent",
    "GET /api/v1/accounts/:account_id/contacts - List contacts",
    "POST /api/v1/accounts/:account_id/contacts - Create contact",
    "GET /api/v1/accounts/:account_id/conversations - List conversations",
    "POST /api/v1/accounts/:account_id/conversations - Create conversation",
    "GET /api/v1/accounts/:account_id/conversations/:id/messages - Get messages",
    "POST /api/v1/accounts/:account_id/conversations/:id/messages - Send message",
    "GET /api/v1/accounts/:account_id/inboxes - List inboxes",
    "POST /api/v1/accounts/:account_id/inboxes - Create inbox",
    "POST /api/v1/accounts/:account_id/webhooks - Create webhook",
    "GET /api/v1/accounts/:account_id/captain/assistants - List AI assistants",
    "POST /api/v1/accounts/:account_id/captain/assistants - Create AI assistant",
    "Widget SDK - window.$chatwoot.init()",
    "Widget SDK - window.$chatwoot.toggle()",
    "Widget SDK - window.$chatwoot.setUser()",
    "Widget SDK - window.$chatwoot.setCustomAttributes()"
  ]
